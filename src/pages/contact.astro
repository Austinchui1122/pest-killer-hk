---
import Base from '../layouts/Base.astro';
---

<Base title="聯絡我們">
	<section class="page-header">
		<div class="container">
			<h1>聯絡我們</h1>
			<p>我們隨時準備為您服務</p>
		</div>
	</section>

	<section class="contact-info">
		<div class="container">
			<div class="contact-grid">
				<div class="contact-details">
					<div class="info-card">
						<h3>即時回覆 <span>WhatsApp</span></h3>
						<p class="phone">5445 8857</p>
						<a href="https://wa.me/85254458857" class="btn btn-primary">即時 WhatsApp 報價</a>
					</div>
					<div class="info-card">
						<h3>服務時間 <span>Opening Hours</span></h3>
						<p>每日 08:00 - 22:00</p>
						<p>全港 18 區服務，最快 2 小時上門。</p>
					</div>
					<div class="info-card">
						<h3>品牌 <span>Brands</span></h3>
						<p>滅蟲職人 (Pest Killer HK)</p>
						<p>匠人潔淨社 (Artisan Cleaning)</p>
					</div>
				</div>

				<div class="contact-form-container">
					<h2>網上查詢 <span>Online Inquiry</span></h2>
					<form class="contact-form">
						<div class="form-group">
							<label>姓名 Name</label>
							<input type="text" placeholder="您的姓名" required />
						</div>
						<div class="form-group">
							<label>電話 Phone</label>
							<input type="tel" placeholder="您的聯絡電話" required />
						</div>
						<div class="form-group">
							<label>蟲害類型 Pest Type</label>
							<select>
								<option value="bedbug">床蝨</option>
								<option value="rat">老鼠</option>
								<option value="termite">白蟻</option>
								<option value="cockroach">蟑螂</option>
								<option value="other">其他</option>
							</select>
						</div>
						<div class="form-group">
							<label>內容 Message</label>
							<textarea placeholder="您的具體需求或情況" rows="5"></textarea>
						</div>
						<button type="submit" class="btn btn-primary" style="width: 100%;">發送查詢 Send Inquiry</button>
					</form>
				</div>
			</div>
		</div>
	</section>

	<style>
		.page-header {
			background: var(--primary);
			color: white;
			padding: 80px 0;
			text-align: center;
		}
		.page-header h1 { font-size: 2.5rem; margin-bottom: 10px; }
		.page-header p { font-size: 1.2rem; opacity: 0.8; }

		.contact-info {
			padding: 80px 0;
		}
		.contact-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 60px;
		}
		.info-card {
			margin-bottom: 40px;
			padding: 30px;
			background: var(--light-gray);
			border-radius: 10px;
			border-left: 5px solid var(--primary);
		}
		.info-card h3 {
			margin-bottom: 15px;
			color: var(--primary);
		}
		.info-card h3 span {
			display: block;
			font-size: 0.9rem;
			color: var(--text);
			opacity: 0.6;
		}
		.info-card p {
			font-size: 1.1rem;
			margin-bottom: 10px;
		}
		.info-card p.phone {
			font-size: 2rem;
			font-weight: 700;
			color: var(--accent);
			margin-bottom: 20px;
		}

		.contact-form-container {
			background: white;
			padding: 40px;
			border-radius: 10px;
			box-shadow: 0 5px 30px rgba(0,0,0,0.1);
		}
		.contact-form-container h2 {
			margin-bottom: 30px;
			color: var(--primary);
		}
		.contact-form-container h2 span {
			display: block;
			font-size: 1rem;
			color: var(--text);
			opacity: 0.6;
		}
		.form-group {
			margin-bottom: 20px;
		}
		.form-group label {
			display: block;
			margin-bottom: 8px;
			font-weight: 500;
		}
		.form-group input, .form-group select, .form-group textarea {
			width: 100%;
			padding: 12px;
			border: 1px solid #ddd;
			border-radius: 5px;
			font-family: inherit;
		}
		.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
			border-color: var(--primary);
			outline: none;
		}

		@media (max-width: 992px) {
			.contact-grid {
				grid-template-columns: 1fr;
				gap: 40px;
			}
		}
	</style>
</Base>
